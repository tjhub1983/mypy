[case testTypeOperatorInGenericClass]
# Test type operators in generic class context
from typing import Generic, TypeVar
from m import IsSub, _Cond

T = TypeVar('T')

class MyClass(Generic[T]):
    # Ternary syntax in class attribute
    attr: str if IsSub[T, int] else float

    # _Cond in method signature
    def method(self, x: _Cond[IsSub[T, str], list[T], T]) -> None:
        pass

