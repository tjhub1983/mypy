[case testTypeOperatorInTypeAlias]
# Test type operators in type aliases (using concrete types to avoid unbound typevar issues)
from m import IsSub, _Cond

# Type alias using _Cond with concrete types
ConditionalType = _Cond[IsSub[int, object], str, bytes]

# Note: Ternary syntax at module level without TypeAlias annotation is treated as
# a runtime expression, not a type alias. The ternary syntax works best in
# annotations (function signatures, variable annotations, class attributes).

